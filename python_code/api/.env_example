# ── LLM ───────────────────────────────────────────────────────────────────────
# Option A — Groq (free tier, recommended for local dev)
#   1. Sign up at https://console.groq.com → API Keys → Create API Key
#   2. Set RUNPOD_CHATBOT_URL to the Groq base URL below
RUNPOD_TOKEN=your_groq_or_runpod_api_key_here
RUNPOD_CHATBOT_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.1-8b-instant

# Option B — RunPod (production)
# RUNPOD_TOKEN=your_runpod_token
# RUNPOD_CHATBOT_URL=https://api.runpod.ai/v2/<endpoint_id>/openai/v1
# MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# ── Embeddings + RAG (optional — details agent disabled without these) ─────────
# Leave blank to run without RAG. Order, guard, and recommendation agents work fine.
# To enable: set up Pinecone free tier + Ollama (nomic-embed-text) or RunPod embedding endpoint
RUNPOD_EMBEDDING_URL=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
