# ── LLM ───────────────────────────────────────────────────────────────────────
# Option A — Groq (free tier, recommended for local dev)
#   1. Sign up at https://console.groq.com → API Keys → Create API Key
RUNPOD_TOKEN=your_groq_or_runpod_api_key_here
RUNPOD_CHATBOT_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.3-70b-versatile

# Option B — RunPod (production)
# RUNPOD_TOKEN=your_runpod_token
# RUNPOD_CHATBOT_URL=https://api.runpod.ai/v2/<endpoint_id>/openai/v1
# MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# Option C — Fully local (Ollama)
# RUNPOD_TOKEN=ollama
# RUNPOD_CHATBOT_URL=http://localhost:11434/v1
# MODEL_NAME=gemma4:27b

# ── RAG / Details Agent (optional) ────────────────────────────────────────────
# Embeddings run locally via sentence-transformers (all-MiniLM-L6-v2).
# No external service or API key needed — ChromaDB runs entirely on disk.
#
# Setup:
#   1. Run: cd python_code && python build_index.py
#   2. Restart the backend — DetailsAgent will print "RAG enabled"
#
# Leave unset to run without RAG. Guard, order, and recommendation agents work fine.
# Optional: override the default index path (default: api/chroma_db/)
# CHROMA_DB_PATH=api/chroma_db
